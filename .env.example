# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-id # team: your-team, project: film-fanatic
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Clerk Auth
CONVEX_CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY

# App URLs
VITE_PUBLIC_APP_URL=https://film-fanatic.vercel.app
VITE_PUBLIC_VIDEO_URL=https://www.vidking.net

# TMDB API (read-only public API key — safe for client)
VITE_TMDB_API_KEY=your_tmdb_read_access_token
VITE_PUBLIC_TMDB_API_URL=https://api.themoviedb.org/3

# Convex Deploy
CONVEX_DEPLOY_KEY=prod:your-deployment|your-deploy-key

# Auth0 (if used)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id

# AI Providers (server-only — never expose in client code)
OPENROUTER_API_KEY=sk-or-v1-your-key
GEMINI_API_KEY=your_gemini_key
